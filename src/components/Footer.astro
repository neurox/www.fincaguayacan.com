---
---

<footer id="contacto" class="bg-primary text-white py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-3 gap-12">
      <!-- Company Info -->
      <div>
        <h3 class="text-2xl font-bold mb-4 font-heading">Finca Guayacán</h3>
        <p class="text-white/80 leading-relaxed">
          Productores de huevo orgánico certificado, distinguidos y reconocidos por nuestros sistemas de cría.
        </p>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-xl font-semibold mb-4">Contacto</h4>
        <div class="space-y-3 text-white/80">
          <p class="flex items-center space-x-3">
            <span>📞</span>
            <a href="tel:5535676152" class="hover:text-accent transition-colors">55 3567 6152</a>
          </p>
          <p class="flex items-center space-x-3">
            <span>✉️</span>
            <a href="mailto:info@fincaguayacan.com" class="hover:text-accent transition-colors">info@fincaguayacan.com</a>
          </p>
          <p class="flex items-center space-x-3">
            <span>🌐</span>
            <a href="http://www.fincaguayacan.com/" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">fincaguayacan.com</a>
          </p>
        </div>
      </div>

      <!-- Social -->
      <div>
        <h4 class="text-xl font-semibold mb-4">Síguenos</h4>
        <a
          href="https://www.facebook.com/fincaguayacanmx"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center space-x-2 bg-white/10 hover:bg-white/20 px-6 py-3 rounded-full transition-colors"
        >
          <span>Facebook</span>
          <span>↗</span>
        </a>
      </div>
    </div>

    <div class="border-t border-white/20 mt-12 pt-8 text-center text-white/60">
      <p>&copy; {new Date().getFullYear()} Finca Guayacán - Productos Orgánicos. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>
