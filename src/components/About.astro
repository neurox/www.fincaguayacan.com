<section id="nosotros" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-3xl md:text-4xl font-bold text-primary mb-6 font-heading">
          Sobre Finca Guayacán
        </h2>
        <p class="text-text text-lg mb-6 leading-relaxed">
          Productores de huevo orgánico certificado, distinguidos y reconocidos por nuestros sistemas de cría.
        </p>
        <p class="text-text text-lg mb-8 leading-relaxed">
          Nuestras gallinas viven en libre pastoreo, con una alimentación de la más alta calidad y procesos que priorizan el bienestar animal.
        </p>
        <div class="flex flex-wrap gap-8">
          <div class="text-center">
            <div class="text-3xl font-bold text-primary">4,700+</div>
            <div class="text-text/70">Seguidores</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-primary">100%</div>
            <div class="text-text/70">Orgánico Certificado</div>
          </div>
        </div>
      </div>
      <div>
        <img
          src="/images/farm.jpg"
          alt="Gallinas en libre pastoreo"
          class="rounded-lg shadow-lg w-full h-auto object-cover"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>
